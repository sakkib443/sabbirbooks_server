# ─── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/sabbir-book

# ─── Auth ───────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_SECRET=replace_with_a_strong_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Max concurrent logged-in devices per user (oldest auto-evicted on a new login)
DEVICE_LIMIT=2

# ─── Cloudinary ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SSLCommerz ─────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=false

# ─── bKash ──────────────────────────────────────────────────
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_GRANT_TOKEN_URL=

# ─── Email (Gmail SMTP) ─────────────────────────────────────
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=Sabbir Book
SENDGRID_API_KEY=

# ─── SMS ────────────────────────────────────────────────────
BULKSMS_API_KEY=
BULKSMS_SENDER_ID=SabbirBook

# ─── Client ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
